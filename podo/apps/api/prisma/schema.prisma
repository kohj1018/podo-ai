// Prisma = 폴리글랏 스키마 SSOT (ARCH §3-2 규칙2: DDL은 Prisma 소유).
// 최소 5테이블 + pgvector extension(raw SQL prepend, migration.sql). T-020.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// crawler 소유 (§3-2) — 수집 공고.
model JobPosting {
  id                 Int                @id @default(autoincrement())
  source             String
  company            String
  title              String
  url                String             @unique
  raw_text           String
  role_family        String?
  posted_at          DateTime?
  closing_at         DateTime?
  diff_status        String?
  fetched_at         DateTime           @default(now())
  recommendations    Recommendation[]
  application_events ApplicationEvent[]

  @@map("job_postings")
}

// crawler 소유 — run별 1행(coverage 투명성).
model CrawlRun {
  id           Int      @id @default(autoincrement())
  channel      String
  run_at       DateTime @default(now())
  status       String
  new_count    Int      @default(0)
  closed_count Int      @default(0)
  error        String?

  @@map("crawl_runs")
}

// worker 소유 — evidence opaque JSONB(result) + 결정적 복합 unique 키(캐시 hit = GS-1-through-DB).
model RankingRun {
  id                Int              @id @default(autoincrement())
  resume_id         Int
  job_set_hash      String
  model             String
  prompt_version    String
  scoring_mode      String
  ranking_mode      String
  cache_key_version String
  result            Json
  created_at        DateTime         @default(now())
  resume            Resume           @relation(fields: [resume_id], references: [id])
  recommendations   Recommendation[]

  @@unique([resume_id, job_set_hash, model, prompt_version, scoring_mode, ranking_mode, cache_key_version])
  @@map("ranking_runs")
}

// worker 소유 — feed projection(scalar). NestJS가 opaque JSONB 파싱 없이 정렬·커서 feed 생성.
model Recommendation {
  id               Int        @id @default(autoincrement())
  run_id           Int
  job_posting_id   Int
  rank_position    Int
  fit_level        Int? // nullable — held 공고는 NULL(T-022 pending projection)
  domain_alignment String?
  status           String // scored | held
  run              RankingRun @relation(fields: [run_id], references: [id])
  job_posting      JobPosting @relation(fields: [job_posting_id], references: [id])

  @@unique([run_id, job_posting_id]) // run당 공고 1행 불변식 — DB 승격(QA-M2-002)
  @@index([run_id, rank_position]) // current-run 한정 커서(T-026)
  @@map("recommendations")
}

// api 소유 — 계정 PII 최소 저장(ADR-105 Amend1 §2): provider·account_id·email·display_name·avatar_url만.
// OAuth access/refresh token 미영속. 동일 email + 다른 provider = 별 계정(병합 비범위).
model User {
  id                  String             @id @default(cuid())
  provider            String
  provider_account_id String
  email               String
  display_name        String
  avatar_url          String?
  created_at          DateTime           @default(now())
  resumes             Resume[]
  application_events  ApplicationEvent[]

  @@unique([provider, provider_account_id])
  @@map("users")
}

// api 소유 — 실 이력서 업로드 메타(M3: masked·source·upload_format 추가).
model Resume {
  id            Int          @id @default(autoincrement())
  content       String       // 마스킹본 전용 (raw PII 미저장 — M3 안전 불변식)
  masked        Boolean      @default(false)
  source        String       @default("seed")  // seed | upload | paste
  upload_format String       @default("txt")   // txt | md | paste
  created_at    DateTime     @default(now())
  // user_id nullable — 기존 seed 이력서(user 없음) 하위 호환(T-042)
  user_id       String?
  user          User?        @relation(fields: [user_id], references: [id])
  ranking_runs  RankingRun[]
  scoring_jobs  ScoringJob[]

  @@map("resumes")
}

// api 소유 — 채점 작업 상태 추적(T-044). worker는 직접 write 금지(ARCH §3-2 단일 writer).
// status: queued → running → done | failed (status consumer가 갱신).
model ScoringJob {
  id         String   @id @default(cuid())
  resume_id  Int
  status     String   @default("queued") // queued | running | done | failed
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  resume     Resume   @relation(fields: [resume_id], references: [id])

  @@map("scoring_jobs")
}

// api 소유 — 지원/스킵·즐겨찾기 이벤트 로그(T-050). 이벤트 로그 형식 — GS-3 후속 분석 유리(F-019 §12).
// action: applied | skipped | favorite | unfavorite | unskip
// 멱등: 동일 (user_id, job_posting_id)는 upsert로 최신 action 유지.
model ApplicationEvent {
  id             Int        @id @default(autoincrement())
  user_id        String
  job_posting_id Int
  action         String     // applied | skipped | favorite | unfavorite | unskip
  created_at     DateTime   @default(now())
  user           User       @relation(fields: [user_id], references: [id])
  job_posting    JobPosting @relation(fields: [job_posting_id], references: [id])

  @@unique([user_id, job_posting_id]) // 멱등 upsert 키 — 동일 user×job 최신 action 1행
  @@index([user_id, job_posting_id])
  @@map("application_events")
}
