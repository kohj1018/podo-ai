# podo-ai — 환경변수 예시 (Python 백엔드: uv 워크스페이스 ai/* + crawler).
# 이 파일을 레포 루트에 `.env`로 복사하고 값을 채우세요.
#   PowerShell:  Copy-Item .env.example .env
# `.env`는 커밋되지 않습니다(.gitignore). 비밀값은 절대 커밋하지 마세요.
#
# 로딩: ai/worker/src/worker/config.py 가 레포 루트의 .env를 "결정적으로" 읽습니다
#       (실행 위치 무관). 실제 환경변수가 설정돼 있으면 그게 .env보다 우선합니다(배포 주입 경로).
#
# 폴리글랏 모노레포 env 규약:
#   - 이 루트 .env = Python 백엔드(ai/* + crawler)의 단일 env 소스.
#   - 나중에 추가될 웹(podo/)은 프레임워크 관례대로 자기 디렉터리의 .env를 따로 둡니다
#     (Next.js/Vite는 앱 폴더의 .env*를 자동 인식 — 모노레포 루트를 거슬러 올라가지 않음).
#   - 브라우저에 노출할 변수만 NEXT_PUBLIC_/VITE_ 접두사를 붙이고,
#     OPENAI_API_KEY 같은 백엔드 시크릿은 절대 웹 env(프론트 번들)에 넣지 마세요.

# ── LLM (OpenAI) ──────────────────────────────────────────────
# 필수: OpenAI API 키 (직접 채워넣으세요).
OPENAI_API_KEY=

# 사용할 OpenAI 모델 — 프로토타입(podo-algorithm-test) 검증 모델과 동일하게 둡니다.
OPENAI_MODEL=gpt-5.4-mini

# ── 결정론 핀 (캐시 키 구성요소 — 보통 기본값 유지) ───────────
# 모델/스키마/스코어링 의미가 바뀌어 캐시를 무효화해야 할 때만 변경.
SCHEMA_VERSION=v1
PROMPT_VERSION=v1

# OpenAI seed (모델이 지원할 때만 사용 — 재현성 보조).
LLM_SEED=7

# ── LLM 응답 캐시 (재현성) ────────────────────────────────────
# 동일 입력 → 동일 응답 재현. gpt-5.4-mini는 seed로도 비결정적이라 캐시가 유일한
# 재현 메커니즘(끄면 새로고침마다 fit ±1 흔들림). 캐시는 .cache/llm/ (git-ignore).
# LLM_CACHE=1            # 0/off → 비활성(항상 라이브 호출)
# LLM_CACHE_REFRESH=0    # 1 → 기존 캐시 무시하고 새로 호출·재기록
# LLM_CACHE_DIR=         # 기본 = 레포 루트 .cache/llm

# DB (PostgreSQL + pgvector) — local infra/docker-compose.yml
#   docker compose -f infra/docker-compose.yml up -d
# Matches POSTGRES_USER/PASSWORD/DB (podo) in infra/docker-compose.yml.
DATABASE_URL=postgresql://podo:podo@localhost:5432/podo

# Frontend (Next.js) — only NEXT_PUBLIC_ vars are exposed to the browser.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# ── AWS 배포 (T-082 / M6) ─────────────────────────────────────
# 로컬은 위 DATABASE_URL(docker-compose) + LocalStack SQS를 쓰고, 배포 환경은
# 아래 값을 채웁니다. 배포 시 OPENAI_API_KEY·DATABASE_URL·OAuth secret 실값은
# 커밋하지 말고 AWS Secrets Manager(`podo/<env>/*`)에서 주입하세요(infra/aws/).
# SQS_QUEUE_URL·AWS_REGION은 시크릿이 아니므로 task definition env로 주입 가능.
AWS_REGION=
# `terraform output sqs_queue_url`로 확인한 채점 큐 URL (ADR-106).
SQS_QUEUE_URL=
