# podo-ai — 환경변수 예시.
# 이 파일을 복사해 `.env`로 만들고 값을 채우세요.
#   PowerShell:  Copy-Item .env.example .env
# `.env`는 .gitignore로 커밋되지 않습니다. 비밀값은 절대 커밋하지 마세요.
# 로딩: worker/config.py 의 load_dotenv() 가 실행 위치에서 위로 .env 를 탐색합니다(레포 루트 권장).

# ── LLM (OpenAI) ──────────────────────────────────────────────
# 필수: OpenAI API 키 (직접 채워넣으세요).
OPENAI_API_KEY=

# 사용할 OpenAI 모델 — 프로토타입(podo-algorithm-test) 검증 모델과 동일하게 둡니다.
OPENAI_MODEL=gpt-5.4-mini

# ── 결정론 핀 (캐시 키 구성요소 — 보통 기본값 유지) ───────────
# 모델/스키마/스코어링 의미가 바뀌어 캐시를 무효화해야 할 때만 변경.
SCHEMA_VERSION=v1
PROMPT_VERSION=v1

# OpenAI seed (모델이 지원할 때만 사용 — 재현성 보조).
LLM_SEED=7
